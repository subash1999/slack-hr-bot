{
  "name": "slack-hr-bot",
  "version": "1.0.0",
  "description": "Slack HR Bot — Attendance, Leave, Hours, Payroll",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "build:gas": "node esbuild.config.mjs && cp src/appsscript.json dist/ && cp gas/entrypoints.js dist/",
    "test": "jest --verbose",
    "test:unit": "jest tests/unit --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:coverage": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "push": "npm run build:gas && npx clasp push --force",
    "pull": "npx clasp pull",
    "deploy": "npm run push && npx clasp deploy",
    "e2e": "ts-node tests/e2e/runner.ts",
    "check": "npm run build && npm run lint && npm run test"
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.27.4",
    "esbuild-gas-plugin": "^0.10.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
